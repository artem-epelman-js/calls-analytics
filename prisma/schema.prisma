generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sale {
  id        Int         @id @default(autoincrement())
  stage     String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  call      Call[]
  Live      Live[]
  Messanger Messanger[]
}

model Call {
  id        Int      @id @default(autoincrement())
  agentId   Int?
  date      DateTime
  phone     String
  duration  Int
  price     Decimal  @default(0.25)
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Sale?    @relation(fields: [agentId], references: [id])

  @@unique([phone, date])
}

model Live {
  id        Int      @id @default(autoincrement())
  agentId   Int?
  date      DateTime
  count     Int
  price     Int      @default(17)
  geo       geo      @default(KZ)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Sale?    @relation(fields: [agentId], references: [id])

  @@unique([agentId, geo, date])
}

model Messanger {
  id         Int           @id @default(autoincrement())
  agentId    Int
  date       DateTime
  count      Int
  price      Int           @default(10)
  type       MessangerType
  isRecovery Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  agent      Sale          @relation(fields: [agentId], references: [id])

  @@index([date])
  @@index([agentId])
}

enum MessangerType {
  TELEGRAM
  WHATSAPP
}

enum geo {
  KZ
  KG
  UZ
  BY
}
