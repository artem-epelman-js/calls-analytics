generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sale {
  id        Int         @id @default(autoincrement())
  stage     String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  call      Call[]
  Live      Live[]
  Messanger Messanger[]   // ← ок: у сейла много записей мессенджера
}

model Call {
  id        Int      @id @default(autoincrement())
  agentId   Int?
  date      DateTime
  phone     String
  duration  Int
  price     Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent     Sale?    @relation(fields: [agentId], references: [id])

  @@unique([phone, date])
}

model Live {
  id        Int      @id @default(autoincrement())
  agentId   Int?
  date      DateTime
  count     Int
  geo       geo      @default(KZ)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent     Sale?    @relation(fields: [agentId], references: [id])

  @@unique([agentId, geo, date])
}

enum MessangerType {
  TELEGRAM
  WHATSAPP
}

model Messanger {
  id         Int            @id @default(autoincrement())
  agentId    Int
  date       DateTime
  count      Int
  type       MessangerType
  isRecovery Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // ✅ правильная связь «многие-к-одному» к Sale
  agent      Sale           @relation(fields: [agentId], references: [id])

  // (опционально) частичная уникальность на день/тип
  // @@unique([agentId, type, date])

  @@index([date])
  @@index([agentId])
}

enum geo {
  KZ
  KG
  UZ
  BY
}
